{
  "version": "2026-04-25",
  "description": "ACOS/Starlight multi-provider image routing policy. Pricing verified 2026-04-25 via WebSearch. See docs/superpowers/specs/2026-04-25-infogenius-v2-design.md.",
  "providers": {
    "nano-banana": {
      "mode": "api",
      "defaultModel": "gemini-3-pro-image-preview",
      "displayName": "Nano Banana Pro (Gemini 3 Pro Image)",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent",
      "requiredEnv": ["GEMINI_API_KEY|GOOGLE_GENERATIVE_AI_API_KEY"],
      "strengths": [
        "grounded educational visuals",
        "Gemini-based prompt grounding",
        "brand-consistent reproducibility",
        "existing Claude MCP workflow"
      ],
      "capabilities": {
        "text-rendering": "good",
        "edit-fidelity": "good",
        "web-grounded": true,
        "brand-consistent": "excellent"
      },
      "costPerImage": {
        "simple": 0.134,
        "typical": 0.134,
        "premium4K": 0.24,
        "batch2K": 0.067
      },
      "notes": "Primary for Claude sessions. Use mcp__nanobanana__generate_image in-chat. Always pass imageSize: '2K' for retina hero quality. Fallback CLI calls go through `npm run image:generate` once Gemini API key is wired."
    },
    "openai": {
      "mode": "api",
      "defaultModel": "gpt-image-2",
      "supportedModels": ["gpt-image-2", "gpt-image-1"],
      "displayName": "OpenAI GPT Image 2",
      "requiredEnv": ["OPENAI_API_KEY"],
      "endpoint": "https://api.openai.com/v1/images/generations",
      "strengths": [
        "best-in-class text rendering",
        "high instruction following",
        "production-safe edits and variants",
        "O-series reasoning (thinking mode)",
        "agentic planning + web search"
      ],
      "capabilities": {
        "text-rendering": "excellent",
        "edit-fidelity": "excellent",
        "web-grounded": true,
        "brand-consistent": "good"
      },
      "costPerImage": {
        "simple": 0.04,
        "typical": 0.17,
        "premium": 0.35
      },
      "notes": "gpt-image-2 released 2026-04-21. Pass `thinking_level: 'high'` for complex prompts (raises cost toward premium tier). gpt-image-1 still callable via --model gpt-image-1."
    },
    "xai": {
      "mode": "api",
      "defaultModel": "grok-imagine-image",
      "displayName": "xAI Grok Imagine",
      "requiredEnv": ["XAI_API_KEY"],
      "endpoint": "https://api.x.ai/v1/image/generations",
      "strengths": [
        "stylized creative outputs",
        "fast idea exploration",
        "Grok-native image endpoint"
      ],
      "capabilities": {
        "text-rendering": "fair",
        "edit-fidelity": "fair",
        "web-grounded": false,
        "brand-consistent": "fair"
      },
      "costPerImage": {
        "simple": 0.05,
        "typical": 0.08,
        "premium": 0.12
      }
    },
    "replicate": {
      "mode": "api",
      "defaultModel": "black-forest-labs/flux-1.1-pro",
      "displayName": "Replicate (Flux 1.1 Pro default)",
      "requiredEnv": ["REPLICATE_API_TOKEN"],
      "endpoint": "https://api.replicate.com/v1/predictions",
      "strengths": [
        "broad model marketplace",
        "easy A/B across model families",
        "good throughput for batch variants"
      ],
      "capabilities": {
        "text-rendering": "fair",
        "edit-fidelity": "good",
        "web-grounded": false,
        "brand-consistent": "good"
      },
      "costPerImage": {
        "simple": 0.04,
        "typical": 0.04,
        "premium": 0.06
      }
    }
  },
  "routes": {
    "grounded-infographic": {
      "primary": "nano-banana",
      "fallback": ["openai", "replicate"],
      "reason": "Grounded facts and educational diagrams first; fallback to text-strong renderers."
    },
    "text-heavy-diagram": {
      "primary": "openai",
      "fallback": ["nano-banana", "replicate"],
      "reason": "GPT Image 2 leads on in-image text rendering and labeled schematics."
    },
    "text-in-image": {
      "primary": "openai",
      "fallback": ["nano-banana"],
      "reason": "Headlines, code, multilingual labels rendered crisply inside the image."
    },
    "edit-existing": {
      "primary": "openai",
      "fallback": ["replicate"],
      "reason": "GPT Image 2 has best edit fidelity; pass reference image as input."
    },
    "creative-exploration": {
      "primary": "xai",
      "fallback": ["replicate", "openai"],
      "reason": "Rapid style exploration with Grok, then test alternates."
    },
    "hero-brand": {
      "primary": "nano-banana",
      "fallback": ["openai", "xai"],
      "reason": "FrankX visual consistency via Nano Banana Pro generation history."
    },
    "high-volume-variants": {
      "primary": "replicate",
      "fallback": ["openai", "xai"],
      "reason": "Best for model sweeps and volume generation at lowest cost."
    }
  },
  "priorityRules": {
    "quality": ["openai", "nano-banana", "xai", "replicate"],
    "speed": ["xai", "openai", "replicate", "nano-banana"],
    "cost": ["replicate", "xai", "nano-banana", "openai"]
  },
  "matrixDefaults": {
    "providers": ["openai", "xai", "replicate"],
    "manualProviders": ["nano-banana"]
  }
}
