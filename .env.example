# =============================================================================
# FrankX.AI Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Production URL
NEXTAUTH_URL=https://frankx.ai

# Admin credentials
ADMIN_EMAIL=admin@frankx.ai

# Generate with: node scripts/generate-password-hash.mjs your-password-here
# Default password hash for 'changeme123' (MUST change in production!)
ADMIN_PASSWORD_HASH=$2a$10$YourBcryptHashHere

# Header/body secret for /api/admin/upload and /api/admin/verify — separate
# from the NextAuth session used by every other /admin and /dashboard route.
# No default: those routes fail closed (503) when this is unset.
ADMIN_SECRET=
ADMIN_TOKEN=

# Signs one-click confirm/unsubscribe email links (lib/email-config.ts).
# Generate with: openssl rand -base64 32
EMAIL_TOKEN_SECRET=
NEWSLETTER_TOKEN_SECRET=

# Bearer token Vercel Cron sends when it calls app/api/cron/* handlers.
CRON_SECRET=

# -----------------------------------------------------------------------------
# Vercel KV (Redis) - Persistent Storage
# -----------------------------------------------------------------------------
# Automatically provided by Vercel when you add KV storage
# No manual configuration needed - Vercel injects these at runtime

KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# -----------------------------------------------------------------------------
# Vercel Blob - Private Admin Data Room
# -----------------------------------------------------------------------------
# Automatically provided by Vercel Blob when connected to the project.
# Used by /admin/data-room to stream private strategy documents through auth.

BLOB_READ_WRITE_TOKEN=

# Local-only source root for upload scripts. Do not set this in public clients.
DATA_ROOM_SOURCE_ROOT=../_business-plans/starlight-agentic-venture-os-2026

# Deliberate upload gate. Set only for the command that uploads private docs.
DATA_ROOM_ENABLE_PRIVATE_BLOB_UPLOAD=false

# -----------------------------------------------------------------------------
# Email Delivery (Resend)
# -----------------------------------------------------------------------------
# Get your API key from: https://resend.com/api-keys

RESEND_API_KEY=re_your_api_key_here

# Sender email (must be verified in Resend dashboard)
# Default: frank@frankx.ai
RESEND_FROM_EMAIL=frank@frankx.ai

# -----------------------------------------------------------------------------
# Payments
# -----------------------------------------------------------------------------

# Stripe (app/api/checkout, app/api/webhooks/stripe)
STRIPE_SECRET_KEY=sk_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PRICE_TOOLKIT=
STRIPE_PRICE_ACOS=
STRIPE_PRICE_SUNO=

# Lemon Squeezy (app/api/webhooks/lemon-squeezy)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Newsletter Service (Optional)
# -----------------------------------------------------------------------------

# ConvertKit
NEWSLETTER_PROVIDER=convertkit
CONVERTKIT_API_KEY=your_key_here
CONVERTKIT_FORM_ID=your_form_id_here

# OR Mailchimp
# NEWSLETTER_PROVIDER=mailchimp
# MAILCHIMP_API_KEY=your_key_here
# MAILCHIMP_AUDIENCE_ID=your_audience_id_here

# OR Beehiiv
# BEEHIIV_API_KEY=your_key_here
# BEEHIIV_PUBLICATION_ID=your_publication_id_here

# OR Custom Webhook
# NEWSLETTER_PROVIDER=webhook
# NEWSLETTER_WEBHOOK_URL=https://your-webhook-url.com

# -----------------------------------------------------------------------------
# Notion (workshop intake + CRM sync)
# -----------------------------------------------------------------------------

NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_ENGAGEMENTS_DB_ID=
NOTION_INQUIRIES_DB_ID=
NOTION_ORGS_DB_ID=
NOTION_PEOPLE_DB_ID=
NOTION_VIDEO_DB_ID=
NOTION_WORKSHOPS_DB_ID=

# -----------------------------------------------------------------------------
# Workshops
# -----------------------------------------------------------------------------

WORKSHOP_PORTAL_SECRET=
WORKSHOP_INTAKE_AUDIENCE_ID=

# -----------------------------------------------------------------------------
# Ops notifications
# -----------------------------------------------------------------------------

SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Content Studio — Postiz distribution (optional, draft-only)
# -----------------------------------------------------------------------------
# Unset = /admin/content-studio stays manual (Copy + Open <platform>), no behavior change.
# Set POSTIZ_API_KEY to enable "Send to Postiz" — creates a DRAFT only, never publishes;
# the actual post-live action always happens inside Postiz itself.

# Your Postiz API key (Settings -> Public API in the Postiz dashboard)
POSTIZ_API_KEY=

# Only set for a self-hosted Postiz instance — omit to use https://api.postiz.com
POSTIZ_API_URL=

# Integration ids for your connected channels. Leave POSTIZ_API_KEY set and no integration
# ids configured, then GET /api/content-studio/distribute to read the real ids off your
# connected integrations, then fill these in.
POSTIZ_INTEGRATION_ID_LINKEDIN=
POSTIZ_INTEGRATION_ID_TWITTER=

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------

# Set to 'development' for local dev, 'production' for live
NODE_ENV=production

# =============================================================================
# Security Notes
# =============================================================================
#
# 1. NEVER commit this file with actual values
# 2. Rotate NEXTAUTH_SECRET monthly in production
# 3. Use strong passwords and store hashes, not plain text
# 4. Limit Vercel KV access to necessary environments only
# 5. Enable Resend domain authentication for better deliverability
# 6. Use environment-specific API keys (dev vs prod)
#
# =============================================================================
