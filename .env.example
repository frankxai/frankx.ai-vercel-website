# =============================================================================
# FrankX.AI Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# Production URL
NEXTAUTH_URL=https://frankx.ai

# Admin credentials
ADMIN_EMAIL=admin@frankx.ai

# Generate with: node scripts/generate-password-hash.mjs your-password-here
# Default password hash for 'changeme123' (MUST change in production!)
ADMIN_PASSWORD_HASH=$2a$10$YourBcryptHashHere

# -----------------------------------------------------------------------------
# Vercel KV (Redis) - Persistent Storage
# -----------------------------------------------------------------------------
# Automatically provided by Vercel when you add KV storage
# No manual configuration needed - Vercel injects these at runtime

KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# -----------------------------------------------------------------------------
# Email Delivery (Resend)
# -----------------------------------------------------------------------------
# Get your API key from: https://resend.com/api-keys

RESEND_API_KEY=re_your_api_key_here

# Sender email (must be verified in Resend dashboard)
# Default: frank@frankx.ai
RESEND_FROM_EMAIL=frank@frankx.ai

# -----------------------------------------------------------------------------
# Newsletter Service (Optional)
# -----------------------------------------------------------------------------

# ConvertKit
NEWSLETTER_PROVIDER=convertkit
CONVERTKIT_API_KEY=your_key_here
CONVERTKIT_FORM_ID=your_form_id_here

# OR Mailchimp
# NEWSLETTER_PROVIDER=mailchimp
# MAILCHIMP_API_KEY=your_key_here
# MAILCHIMP_AUDIENCE_ID=your_audience_id_here

# OR Custom Webhook
# NEWSLETTER_PROVIDER=webhook
# NEWSLETTER_WEBHOOK_URL=https://your-webhook-url.com

# -----------------------------------------------------------------------------
# Studio Crew Chat (Vercel AI SDK + AI Gateway)
# -----------------------------------------------------------------------------
# Default model calls route through the Vercel AI Gateway (streaming, fallback,
# cost/latency observability). Vercel auto-injects AI_GATEWAY_API_KEY on deploy
# when the project has Gateway access; locally run `vercel env pull`.
# Without the Gateway, the chat shows a graceful "studio offline" message
# unless the visitor brings their own key (BYOK, client-side localStorage).

AI_GATEWAY_API_KEY=

# Gateway model strings (provider/model). Swap as new generations ship.
STUDIO_MODEL_FREE=google/gemini-2.5-flash
STUDIO_MODEL_PRO=google/gemini-2.5-pro
# BYOK uses the visitor's own Google key → bare Gemini model id (no prefix).
STUDIO_MODEL_BYOK=gemini-2.5-pro

# Freemium daily caps per identifier (IP for anon, userId for signed-in).
STUDIO_FREE_LIMIT=10
STUDIO_SIGNEDIN_LIMIT=50

# Semantic search (RAG) — Upstash Vector with a built-in embedding model.
# Create an index at https://console.upstash.com/vector (embedding model e.g.
# bge-base-en-v1.5), set these, then run: npm run rag:index
# When absent, the chat falls back to lexical search over the catalog.
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# -----------------------------------------------------------------------------
# Analytics (Optional)
# -----------------------------------------------------------------------------

# Plausible Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=frankx.ai

# Google Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------

# Set to 'development' for local dev, 'production' for live
NODE_ENV=production

# =============================================================================
# Security Notes
# =============================================================================
#
# 1. NEVER commit this file with actual values
# 2. Rotate NEXTAUTH_SECRET monthly in production
# 3. Use strong passwords and store hashes, not plain text
# 4. Limit Vercel KV access to necessary environments only
# 5. Enable Resend domain authentication for better deliverability
# 6. Use environment-specific API keys (dev vs prod)
#
# =============================================================================
