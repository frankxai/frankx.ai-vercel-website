# Vercel Blob Storage
# Get your token from: https://vercel.com/dashboard/stores
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxx

# Private admin data room source folder for local upload scripts
DATA_ROOM_SOURCE_ROOT=../_business-plans/starlight-agentic-venture-os-2026
DATA_ROOM_ENABLE_PRIVATE_BLOB_UPLOAD=false

# Resend Email API
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Instructions:
# 1. Copy this file to .env.local
# 2. Fill in your actual API keys
# 3. Never commit .env.local to git (already in .gitignore)
