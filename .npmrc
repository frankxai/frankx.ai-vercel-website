# Allow npm to resolve peer dependency conflicts
# Required for @react-three packages that require React 19
# while project uses React 18
legacy-peer-deps=true

# Hoist transitively-present packages that are direct-imported but not in package.json
# Needed for pnpm strict node_modules (Vercel build).
# Note: an explicit public-hoist-pattern replaces pnpm's defaults entirely, so the
# *eslint*/*prettier* lines below are re-added to keep the default linting toolchain
# from breaking; @mdx-js/mdx, d3, and mermaid are the packages this fix exists for.
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@mdx-js/mdx
public-hoist-pattern[]=d3
public-hoist-pattern[]=mermaid
