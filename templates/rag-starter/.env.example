# Supabase — create a project at https://supabase.com, run supabase/schema.sql,
# then copy these from Project Settings -> API.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Provider key fallback (optional). BYOK is the default path: the app reads the
# key from the `x-provider-key` request header and never persists it. Set this
# only if you want a server-side default for local development.
# OPENAI_API_KEY=sk-...
