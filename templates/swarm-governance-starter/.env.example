# Optional: route spend checks through the sibling agent-payments-guard MCP server.
# The command is spawned as a LOCAL child process over stdio — no network involved.
# When set and the guard errors or is unreachable, spend checks fail closed
# (reject) — they never silently fall back.
# GUARD_MCP_COMMAND="node ../agent-payments-guard/dist/src/index.js"

# Local caps fallback, used when GUARD_MCP_COMMAND is not set. The file's
# "streams" map uses the same shape as the guard's caps.json, so one file can
# serve both. Defaults to ./swarm.example.json.
# CAPS_PATH=./swarm.example.json
