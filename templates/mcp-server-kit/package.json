{
  "name": "mcp-server-kit",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript Model Context Protocol server starter (stdio + streamable HTTP)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-server-kit": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "start:http": "node dist/index.js --http",
    "dev:http": "tsx src/index.ts --http"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
