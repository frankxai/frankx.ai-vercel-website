# Port for the streamable-HTTP transport (only used with --http).
PORT=3000

# Host to bind the HTTP transport to. Defaults to loopback (127.0.0.1) — the
# server is not reachable from the network unless you set this explicitly.
# HOST=0.0.0.0

# Comma-separated list of allowed Origin header prefixes for the HTTP
# transport (mitigates local-network / DNS-rebinding access). Requests with
# no Origin header (curl, the MCP CLI) are always allowed.
# ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# The example tools call no external APIs. If you add a tool that needs a
# secret, read it from the environment here — never hardcode it in source.
# WEATHER_API_KEY=...
