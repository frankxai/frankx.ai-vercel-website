# Port for the streamable-HTTP transport (only used with --http; stdio needs
# none of this block).
PORT=3000

# Host to bind the HTTP transport to. Defaults to loopback (127.0.0.1) — the
# server is not reachable from the network unless you set this explicitly.
# HOST=0.0.0.0

# Comma-separated list of allowed Origin header prefixes for the HTTP
# transport (mitigates local-network / DNS-rebinding access). Requests with
# no Origin header (curl, the MCP CLI) are always allowed.
# ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Spend-cap policy file. Operator-owned: the calling agent can never supply
# caps as tool input. Copy caps.example.json to caps.json and edit. A missing
# or malformed file means every charge REJECTS (fail closed).
# CAPS_PATH=./caps.json

# Append-only audit log (JSONL). Audit-first: if this write fails, the verdict
# is withheld and the action fails.
# AUDIT_LOG_PATH=./.guard-data/audit.jsonl

# Durable spend ledger (JSONL): consumed mandate ids + spend events. This file
# is why replay protection and per-day totals survive a restart.
# LEDGER_PATH=./.guard-data/ledger.jsonl

# Issuer public keys for mandate verification, one env var per issuer key id.
# Value is a PEM public key or base64-encoded SPKI DER. The built-in `k_dev`
# key is PUBLICLY KNOWN — dev and tests only, never live funds.
# GUARD_ISSUER_PUBKEY_k_prod="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
